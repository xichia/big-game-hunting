{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "manager": {
      "description": "Routes work between specialist agents. Plans, assigns, reviews outputs, and decides escalation. Does not edit code.",
      "mode": "primary",
      "model": "opencode-go/glm-5.2",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/manager.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "task": "allow",
        "edit": "deny",
        "bash": {
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "npm test*": "ask",
          "pnpm test*": "ask",
          "*": "ask"
        }
      }
    },

    "scout": {
      "description": "Fast read-only codebase explorer. Use for finding files, tracing symbols, summarizing modules, and gathering context cheaply.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/scout.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": "deny"
      }
    },

    "architect": {
      "description": "Senior design agent. Use for architecture, migrations, auth, data model changes, large refactors, and high-risk decisions.",
      "mode": "subagent",
      "model": "opencode-go/glm-5.2",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/architect.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": {
          "git status*": "allow",
          "git diff*": "allow",
          "*": "ask"
        }
      }
    },

    "implementer": {
      "description": "Main coding agent. Use for feature implementation, refactors, and applying approved plans.",
      "mode": "subagent",
      "model": "opencode-go/kimi-k2.7-code",
      "temperature": 0.2,
      "prompt": "{file:./.opencode/prompts/implementer.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "ask",
        "bash": {
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "bun test*": "allow",
          "npm run *": "ask",
          "pnpm *": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "*": "ask"
        }
      }
    },

    "fixer": {
      "description": "Debugging and failing-test repair agent. Use after implementation when tests fail or behavior is wrong.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/fixer.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "ask",
        "bash": {
          "npm test*": "allow",
          "pnpm test*": "allow",
          "yarn test*": "allow",
          "bun test*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "*": "ask"
        }
      }
    },

    "reviewer": {
      "description": "Final read-only reviewer. Use for diff review, edge cases, security, regressions, and merge readiness.",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "lsp": "allow",
        "edit": "deny",
        "bash": {
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "*": "ask"
        }
      }
    },

    "docs": {
      "description": "Documentation, README, comments, changelog, examples, and user-facing explanations.",
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "temperature": 0.3,
      "prompt": "{file:./.opencode/prompts/docs.md}",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "ask",
        "bash": {
          "git diff*": "allow",
          "*": "ask"
        }
      }
    }
  }
}
